{
    "name": "philiprehberger/laravel-model-diff",
    "description": "Track and display structured differences between Eloquent model versions with human-readable labels.",
    "keywords": [
        "laravel",
        "eloquent",
        "diff",
        "model",
        "audit",
        "changelog"
    ],
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/philiprehberger/laravel-model-diff",
    "authors": [
        {
            "name": "Philip Rehberger",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^1.12|^2.0",
        "nunomaduro/larastan": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\ModelDiff\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\ModelDiff\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PhilipRehberger\\ModelDiff\\ModelDiffServiceProvider"
            ],
            "aliases": {
                "ModelDiff": "PhilipRehberger\\ModelDiff\\Facades\\ModelDiff"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
